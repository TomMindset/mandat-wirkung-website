---
import Button from "@components/Button.astro";
import CTASection from "@components/CTASection.astro";
import Layout from "@layouts/Layout.astro";
import { landingNavigation } from "@data/navigation";

interface LandingSection {
  title: string;
  text?: string;
  items?: string[];
}

interface Props {
  title: string;
  description: string;
  h1: string;
  focus: string;
  intro: string;
  sections: LandingSection[];
}

const { title, description, h1, focus, intro, sections } = Astro.props;
---

<Layout title={title} description={description}>
  <main>
    <section class="surface-grid bg-paper py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.16em] text-copper">Fokusthema</p>
        <div class="grid gap-10 lg:grid-cols-[1fr_22rem] lg:items-start">
          <div>
            <h1 class="text-balance text-4xl font-semibold leading-tight text-graphite sm:text-5xl">{h1}</h1>
            <p class="mt-7 max-w-3xl text-pretty text-lg leading-8 text-slategraph">{intro}</p>
            <p class="mt-5 max-w-3xl text-sm leading-7 text-slategraph"><strong>SEO-Fokus:</strong> {focus}</p>
            <div class="mt-9 flex flex-col gap-3 sm:flex-row">
              <Button href="/kontakt">Orientierungsgespräch anfragen</Button>
              <Button href="/coaching" variant="secondary">Coaching-Angebote ansehen</Button>
            </div>
          </div>
          <nav class="border border-graphite/12 bg-white p-6 shadow-quiet" aria-label="Weitere Fokusthemen">
            <p class="text-sm font-semibold text-graphite">Weitere Fokusthemen</p>
            <ul class="mt-4 space-y-3 text-sm text-slategraph">
              {landingNavigation.map((item) => <li><a class="hover:text-petrol" href={item.href}>{item.label}</a></li>)}
            </ul>
          </nav>
        </div>
      </div>
    </section>
    <section class="bg-paper py-16 sm:py-20">
      <div class="mx-auto grid max-w-7xl gap-6 px-5 sm:px-8 lg:grid-cols-2">
        {
          sections.map((section) => (
            <article class="border border-graphite/12 bg-white p-7 shadow-quiet">
              <h2 class="text-2xl font-semibold text-graphite">{section.title}</h2>
              {section.text && <p class="mt-4 text-pretty leading-8 text-slategraph">{section.text}</p>}
              {section.items && (
                <ul class="mt-5 grid gap-3 text-slategraph">
                  {section.items.map((item) => <li class="border-t border-graphite/10 pt-3">{item}</li>)}
                </ul>
              )}
            </article>
          ))
        }
      </div>
    </section>
    <CTASection title="Eine Führungsfrage braucht Klarheit vor dem nächsten Schritt?" text="Im vertraulichen Orientierungsgespräch klären wir, ob und wie ein Coaching-Rahmen sinnvoll ist." />
  </main>
</Layout>
