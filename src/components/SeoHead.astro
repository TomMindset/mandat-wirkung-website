---
import { site } from "@data/site";
import { landingNavigation, legalNavigation, primaryNavigation } from "@data/navigation";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
}

const { title, description, canonical = Astro.url.pathname, image = site.ogImage } = Astro.props;
const canonicalUrl = new URL(canonical, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const logoUrl = new URL("/assets/logo-mandat-wirkung.png", site.url).toString();
const currentPath = new URL(canonicalUrl).pathname.replace(/\/$/, "") || "/";

const pageLabels = new Map<string, string>([
  ["/", site.name],
  ...primaryNavigation.map((item) => [item.href, item.label] as const),
  ...landingNavigation.map((item) => [item.href, item.label] as const),
  ...legalNavigation.map((item) => [item.href, item.label] as const)
]);

const breadcrumbItems =
  currentPath === "/"
    ? []
    : [
        {
          "@type": "ListItem",
          position: 1,
          name: "Startseite",
          item: site.url
        },
        {
          "@type": "ListItem",
          position: 2,
          name: pageLabels.get(currentPath) ?? title.replace(` | ${site.name}`, ""),
          item: canonicalUrl
        }
      ];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "ProfessionalService"],
    "@id": `${site.url}/#organization`,
    name: site.name,
    alternateName: "Mandat und Wirkung",
    url: site.url,
    logo: logoUrl,
    image: imageUrl,
    email: site.email,
    founder: {
      "@type": "Person",
      name: site.owner
    },
    address: {
      "@type": "PostalAddress",
      streetAddress: "Bahnhofstraße 75",
      postalCode: "71332",
      addressLocality: "Waiblingen",
      addressCountry: "DE"
    },
    areaServed: [
      {
        "@type": "Place",
        name: "Waiblingen"
      },
      {
        "@type": "Place",
        name: "Stuttgart"
      },
      {
        "@type": "Country",
        name: "Deutschland"
      }
    ],
    knowsAbout: [
      "Führungsmandat Coaching",
      "Führungskräfte Coaching",
      "Leadership Coaching",
      "Laterale Führung",
      "Rollenklärung",
      "Führung in Transformation",
      "KI und Führung"
    ],
    availableLanguage: "de"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${site.url}/#website`,
    name: site.name,
    url: site.url,
    inLanguage: "de-DE",
    publisher: {
      "@id": `${site.url}/#organization`
    }
  },
  ...(breadcrumbItems.length
    ? [
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          itemListElement: breadcrumbItems
        }
      ]
    : [])
];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
