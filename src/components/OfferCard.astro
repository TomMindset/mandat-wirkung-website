---
interface Props {
  title: string;
  eyebrow: string;
  duration: string;
  description?: string;
  focus: string;
}

const { title, eyebrow, duration, description, focus } = Astro.props;
---

<article class="flex h-full flex-col border border-graphite/12 bg-white p-6 shadow-quiet">
  <p class="text-sm font-semibold text-copper">{eyebrow}</p>
  <h3 class="mt-4 text-2xl font-semibold text-graphite">{title}</h3>
  {description && <p class="mt-4 text-sm leading-7 text-slategraph">{description}</p>}
  <p class="mt-5 border-t border-graphite/10 pt-5 text-sm font-semibold text-petrol">{duration}</p>
  <p class="mt-3 text-sm leading-7 text-slategraph">Fokus: {focus}</p>
</article>
