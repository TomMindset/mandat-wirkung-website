---
interface Props {
  items: Array<{ title: string; text: string }>;
  columns?: "two" | "three" | "four";
}

const { items, columns = "three" } = Astro.props;
const columnClass = {
  two: "lg:grid-cols-2",
  three: "lg:grid-cols-3",
  four: "lg:grid-cols-4"
};
---

<div class:list={["mt-10 grid gap-4 sm:grid-cols-2", columnClass[columns]]}>
  {
    items.map((item) => (
      <article class="border border-graphite/12 bg-white/62 p-6 shadow-quiet">
        <h3 class="text-lg font-semibold text-graphite">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-slategraph">{item.text}</p>
      </article>
    ))
  }
</div>
