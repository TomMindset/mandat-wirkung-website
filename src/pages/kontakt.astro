---
import { site } from "@data/site";
import Layout from "@layouts/Layout.astro";

const firstMessageHints = [
  "Ihre aktuelle Rolle oder Verantwortung",
  "die Situation, die Sie klären möchten",
  "ob es um ein akutes Thema oder ein längeres Sparring geht",
  "ein grober zeitlicher Rahmen",
  "besondere Anforderungen an Vertraulichkeit"
];
---

<Layout
  title="Kontakt | Mandat & Wirkung"
  description="Vertrauliche Kontaktaufnahme für Führungscoaching, Mandatsklärung und Transformations-Sparring."
>
  <main id="inhalt">
    <section class="surface-grid bg-paper py-16 sm:py-24">
      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.16em] text-copper">Kontakt</p>
        <h1 class="text-balance text-4xl font-semibold leading-tight text-graphite sm:text-5xl">Vertrauliches Orientierungsgespräch anfragen</h1>
        <p class="mt-7 text-lg leading-8 text-slategraph">
          Wenn Sie vor einer Führungsfrage stehen, die intern schwer zu sortieren ist, können Sie ein vertrauliches Orientierungsgespräch anfragen.
        </p>
        <p class="mt-5 text-lg leading-8 text-slategraph">
          Für eine erste Einschätzung genügen wenige Sätze. Entscheidend ist nicht die perfekte Beschreibung, sondern ein klares Anliegen und ein vertraulicher Rahmen.
        </p>
        <div class="mt-10 border border-graphite/12 bg-white p-6 shadow-quiet">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">Kontakt</p>
          <a class="mt-4 inline-block text-xl font-semibold text-petrol hover:text-ink" href={`mailto:${site.email}`}>{site.email}</a>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="inline-flex min-h-12 items-center justify-center border border-petrol bg-petrol px-5 py-3 text-sm font-semibold text-white hover:bg-ink" href={site.bookingUrl} target="_blank" rel="noopener noreferrer">
              Termin direkt buchen
            </a>
            <a class="inline-flex min-h-12 items-center justify-center border border-copper px-5 py-3 text-sm font-semibold text-graphite hover:bg-copper hover:text-white" href={site.mailtoOrientation}>
              Vertrauliche Anfrage senden
            </a>
          </div>
          <p class="mt-6 text-sm leading-7 text-slategraph">
            Die Terminbuchung öffnet meetergo in einem neuen Fenster. Alternativ können Sie bewusst per E-Mail Kontakt aufnehmen.
          </p>
        </div>
      </div>
    </section>
    <section class="bg-paper py-16 sm:py-20">
      <div class="mx-auto max-w-4xl px-5 sm:px-8">
        <h2 class="text-3xl font-semibold text-graphite">Hilfreich für die erste Nachricht</h2>
        <p class="mt-6 text-lg leading-8 text-slategraph">Für eine erste Einschätzung genügen wenige Sätze. Hilfreich sind:</p>
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {firstMessageHints.map((hint) => <p class="border border-graphite/12 bg-white px-5 py-4 text-sm font-semibold leading-7 text-slategraph shadow-quiet">{hint}</p>)}
        </div>
      </div>
    </section>
  </main>
</Layout>
