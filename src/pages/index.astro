---
import Button from "@components/Button.astro";
import CardGrid from "@components/CardGrid.astro";
import ContentSection from "@components/ContentSection.astro";
import CTASection from "@components/CTASection.astro";
import Hero from "@components/Hero.astro";
import OfferCard from "@components/OfferCard.astro";
import Layout from "@layouts/Layout.astro";
import { offers } from "@data/offers";
import { landingNavigation } from "@data/navigation";
import { site } from "@data/site";

const statements = [
  { title: "Unklares Mandat", text: "Verantwortung ist da, Entscheidungsspielraum und Rückendeckung sind es noch nicht." },
  { title: "Laterale Wirkung", text: "Sie müssen Menschen gewinnen, die Ihnen nicht direkt berichten." },
  { title: "Politische Dynamik", text: "Fachliche Stärke reicht nicht mehr aus; Wirkung entsteht im System." },
  { title: "Transformation", text: "Sie führen Veränderung, bevor alle Voraussetzungen geklärt sind." },
  { title: "Kritische Gespräche", text: "Ein Termin braucht Klarheit, Haltung und präzise Vorbereitung." }
];

const audiences = [
  { title: "Neue Führungsrolle", text: "Mehr Sichtbarkeit, mehr Erwartung, weniger Eindeutigkeit." },
  { title: "Laterale Führung", text: "Verantwortung übernehmen, ohne formale Macht zu überziehen." },
  { title: "Transformation", text: "Orientierung geben, wenn Interessen und Sprachen auseinanderlaufen." },
  { title: "Daten, KI, Digitales", text: "Komplexität übersetzen, ohne sich in Fachlichkeit zu verlieren." }
];

const topics = [
  "Rollenklärung",
  "Führungsmandat",
  "Stakeholder-Wirkung",
  "Kommunikation nach oben und zur Seite",
  "Laterale Führung",
  "Entscheidungssicherheit",
  "Umgang mit Widerstand",
  "Selbstführung unter Druck",
  "Grenzen und Prioritäten",
  "Kritische Gespräche"
];

const formats = [
  "1:1 online oder vor Ort",
  "60 oder 90 Minuten",
  "vertraulich",
  "konkretes Anliegen",
  "Pakete über 3, 6 oder 10 Sessions",
  "Akutsparring bei Bedarf"
];
---

<Layout title={site.defaultTitle} description={site.defaultDescription}>
  <main id="inhalt">
    <Hero
      eyebrow={site.claim}
      title="Klarheit für Rolle, Mandat und Wirkung."
      text="Vertrauliches Coaching für Führungskräfte und Schlüsselpersonen, wenn Verantwortung sichtbar wird und der Auftrag noch nicht eindeutig ist."
      secondaryHref="/anlaesse"
      secondaryLabel="Anlässe ansehen"
    />

    <ContentSection
      title="Wenn Verantwortung mehr Klarheit braucht"
      text="Mandat & Wirkung arbeitet dort, wo Rolle, Erwartungen und Entscheidungsspielraum nicht sauber zusammenpassen."
    >
      <CardGrid items={statements} columns="three" />
    </ContentSection>

    <ContentSection title="Für Menschen, die Wirkung im System erzielen müssen" tone="grid">
      <CardGrid items={audiences} columns="four" />
    </ContentSection>

    <ContentSection
      title="Woran wir arbeiten"
      text="Die Arbeit bleibt konkret: an Ihrer Rolle, Ihren Gesprächen, Ihren Entscheidungen."
    >
      <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {topics.map((topic) => <p class="border border-mist/60 bg-white px-4 py-4 text-sm font-semibold text-slategraph shadow-quiet">{topic}</p>)}
      </div>
    </ContentSection>

    <ContentSection
      title="Vertraulich. Präzise. Auf Augenhöhe."
      text="Kein Training, keine Beratungsschablone. Ein strukturierter Raum für Führungsfragen, die intern schwer neutral zu sortieren sind."
      tone="dark"
    >
      <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {formats.map((format) => <p class="border border-white/12 bg-white/6 px-5 py-4 text-sm font-semibold text-paper/82">{format}</p>)}
      </div>
    </ContentSection>

    <section class="bg-paper py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <div class="max-w-3xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.16em] text-copper">Angebote</p>
          <h2 class="text-balance text-3xl font-semibold leading-tight text-graphite sm:text-4xl">Vier klare Rahmen</h2>
          <p class="mt-6 text-lg leading-8 text-slategraph">So viel Struktur wie nötig, so wenig Programm wie möglich.</p>
        </div>
        <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
          {offers.map((offer) => <OfferCard {...offer} />)}
        </div>
      </div>
    </section>

    <ContentSection
      title="Erfahrung aus Führung und Transformation"
      text="Der Blick richtet sich auf Organisation, Macht, Kommunikation und persönliche Verantwortung. Nicht abstrakt, sondern an der konkreten Situation."
      tone="grid"
    >
      <p class="mt-7 max-w-3xl text-lg leading-8 text-slategraph">Die persönliche Passung klärt sich im vertraulichen Orientierungsgespräch.</p>
      <Button href="/ueber" variant="secondary" class="mt-8">Mehr über Mandat & Wirkung</Button>
    </ContentSection>

    <section class="bg-paper py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <h2 class="text-2xl font-semibold text-graphite">Fokusthemen</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {landingNavigation.map((item) => <a class="border border-mist/60 bg-white px-5 py-4 text-sm font-semibold text-slategraph shadow-quiet hover:text-copper" href={item.href}>{item.label}</a>)}
        </div>
      </div>
    </section>

    <CTASection
      title="Sie stehen vor einer Führungsfrage, die intern schwer zu sortieren ist?"
      text="Dann reicht für den Anfang eine kurze, vertrauliche Einordnung."
    />
  </main>
</Layout>
